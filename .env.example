APP_NAME=Anki Concursos API
APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://anki:anki@localhost:5432/anki_concursos
REDIS_URL=redis://localhost:6379/0
ADMIN_API_KEY=replace-with-a-long-random-secret
ALLOW_LEGACY_ADMIN_API_KEY=true
AUTH_SECRET_KEY=replace-with-at-least-32-random-characters
ACCESS_TOKEN_EXPIRE_MINUTES=60
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-password
BOOTSTRAP_ADMIN_NAME=System administrator
CORS_ORIGINS=http://localhost:3000
PUBLIC_REPORT_RATE_LIMIT=20
PUBLIC_REPORT_RATE_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT=10
LOGIN_RATE_WINDOW_SECONDS=60
DOCS_ENABLED=true
